import pygame
import random
import sys
import psutil

# --- CONFIG ---
INTERNAL_WIDTH = 640
INTERNAL_HEIGHT = 480
NUM_OBJECTS = 2000

pygame.init()

info = pygame.display.Info()
WINDOW_WIDTH = info.current_w
WINDOW_HEIGHT = info.current_h

screen = pygame.display.set_mode(
    (WINDOW_WIDTH, WINDOW_HEIGHT),
    pygame.FULLSCREEN
)

clock = pygame.time.Clock()

render_target = pygame.Surface((INTERNAL_WIDTH, INTERNAL_HEIGHT)).convert()
scaled_surface = pygame.Surface((WINDOW_WIDTH, WINDOW_HEIGHT)).convert()

# CPU tracking
process = psutil.Process()
cpu_usage = 0
frame_counter = 0

fullscreen = True

class Particle:
    def __init__(self):
        self.x = random.uniform(0, INTERNAL_WIDTH)
        self.y = random.uniform(0, INTERNAL_HEIGHT)
        self.vx = random.uniform(-100, 100)
        self.vy = random.uniform(-100, 100)
        self.size = random.randint(2, 5)

    def update(self, dt):
        self.x += self.vx * dt
        self.y += self.vy * dt

        if self.x < 0 or self.x > INTERNAL_WIDTH:
            self.vx *= -1
        if self.y < 0 or self.y > INTERNAL_HEIGHT:
            self.vy *= -1

    def draw(self, surface):
        surface.fill((255, 255, 255), (self.x, self.y, self.size, self.size))


particles = [Particle() for _ in range(NUM_OBJECTS)]

while True:
    dt = clock.tick(60) / 1000.0
    frame_counter += 1

    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            pygame.quit()
            sys.exit()

        if event.type == pygame.KEYDOWN:
            if event.key == pygame.K_ESCAPE:
                pygame.quit()
                sys.exit()

            if event.key == pygame.K_F11:
                fullscreen = not fullscreen

                if fullscreen:
                    info = pygame.display.Info()
                    WINDOW_WIDTH = info.current_w
                    WINDOW_HEIGHT = info.current_h
                    screen = pygame.display.set_mode(
                        (WINDOW_WIDTH, WINDOW_HEIGHT),
                        pygame.FULLSCREEN
                    )
                else:
                    WINDOW_WIDTH, WINDOW_HEIGHT = 1280, 960
                    screen = pygame.display.set_mode(
                        (WINDOW_WIDTH, WINDOW_HEIGHT)
                    )

                scaled_surface = pygame.Surface((WINDOW_WIDTH, WINDOW_HEIGHT)).convert()

    # --- UPDATE ---
    for p in particles:
        p.update(dt)

    # --- DRAW ---
    render_target.fill((10, 10, 20))
    for p in particles:
        p.draw(render_target)

    # CPU scaling
    pygame.transform.scale(
        render_target,
        (WINDOW_WIDTH, WINDOW_HEIGHT),
        scaled_surface
    )

    screen.blit(scaled_surface, (0, 0))
    pygame.display.flip()

    # CPU update
    if frame_counter % 30 == 0:
        cpu_usage = process.cpu_percent(interval=None)

    pygame.display.set_caption(
        f"[SW] FPS: {clock.get_fps():.1f} | Objects: {NUM_OBJECTS} | CPU: {cpu_usage:.1f}%"
    )